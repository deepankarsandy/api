{
  "name": "api",
  "version": "1.0.50",
  "scripts": {
    "test": "bun run scripts/run-tests.ts all",
    "test:watch": "bun run scripts/run-tests.ts all --watch",
    "test:unit": "bun run scripts/run-tests.ts unit",
    "test:integration": "bun run scripts/run-tests.ts integration",
    "test:e2e": "bun run scripts/run-tests.ts e2e",
    "test:coverage": "bun run scripts/run-tests.ts all --coverage",
    "dev": "bun run --watch src/index.ts",
    "dev:debug": "bun --inspect --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "elysia": "^1.4.27",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "bun-types": "^1.3.10",
    "lefthook": "^2.1.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "module": "src/index.js",
  "type": "module"
}
